{
  "name": "idempotency-middleware",
  "version": "1.0.0",
  "description": "Framework-agnostic idempotency cache middleware for TypeScript applications",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "homepage": "https://github.com/reaatech/idempotency-middleware#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reaatech/idempotency-middleware.git"
  },
  "bugs": {
    "url": "https://github.com/reaatech/idempotency-middleware/issues"
  },
  "keywords": [
    "idempotency",
    "middleware",
    "cache",
    "express",
    "koa",
    "typescript",
    "redis",
    "firestore",
    "dynamodb"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/frameworks/express.d.ts",
        "default": "./dist/frameworks/express.js"
      },
      "require": {
        "types": "./dist/frameworks/express.d.cts",
        "default": "./dist/frameworks/express.cjs"
      }
    },
    "./koa": {
      "import": {
        "types": "./dist/frameworks/koa.d.ts",
        "default": "./dist/frameworks/koa.js"
      },
      "require": {
        "types": "./dist/frameworks/koa.d.cts",
        "default": "./dist/frameworks/koa.cjs"
      }
    },
    "./redis": {
      "import": {
        "types": "./dist/adapters/redis.d.ts",
        "default": "./dist/adapters/redis.js"
      },
      "require": {
        "types": "./dist/adapters/redis.d.cts",
        "default": "./dist/adapters/redis.cjs"
      }
    },
    "./dynamodb": {
      "import": {
        "types": "./dist/adapters/dynamodb.d.ts",
        "default": "./dist/adapters/dynamodb.js"
      },
      "require": {
        "types": "./dist/adapters/dynamodb.d.cts",
        "default": "./dist/adapters/dynamodb.cjs"
      }
    },
    "./firestore": {
      "import": {
        "types": "./dist/adapters/firestore.d.ts",
        "default": "./dist/adapters/firestore.js"
      },
      "require": {
        "types": "./dist/adapters/firestore.d.cts",
        "default": "./dist/adapters/firestore.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.57.0",
    "express": "^5.2.1",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.4.1",
    "prettier": "^3.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.3",
    "vitest": "^1.3.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3.50.0",
    "@aws-sdk/lib-dynamodb": "^3.50.0",
    "@aws-sdk/util-dynamodb": "^3.50.0",
    "@google-cloud/firestore": "^7.0.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "koa": "^2.14.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-dynamodb": {
      "optional": true
    },
    "@aws-sdk/lib-dynamodb": {
      "optional": true
    },
    "@aws-sdk/util-dynamodb": {
      "optional": true
    },
    "@google-cloud/firestore": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "koa": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
