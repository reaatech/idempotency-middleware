{
  "name": "@reaatech/idempotency-middleware-express",
  "version": "1.0.0",
  "description": "Express middleware for @reaatech/idempotency-middleware",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/idempotency-middleware.git",
    "directory": "packages/express"
  },
  "homepage": "https://github.com/reaatech/idempotency-middleware/tree/main/packages/express#readme",
  "bugs": {
    "url": "https://github.com/reaatech/idempotency-middleware/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@reaatech/idempotency-middleware": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.6",
    "@types/supertest": "^6.0.0",
    "express": "^5.2.1",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": false
    }
  }
}
